# Local tooling / workspace (contains machine-local settings)
.claude/
.claude_workspace/

# Vendor repos (cloned separately)
vendors/*/
!vendors/.gitkeep
# In-repo vendor wrappers — commit glue code, not the venv or data
!vendors/pytdc/
vendors/pytdc/*
!vendors/pytdc/entry.py
!vendors/pytdc/README.md
!vendors/pytdc/requirements.txt
!vendors/dicom_mcp/
vendors/dicom_mcp/*
!vendors/dicom_mcp/config.yaml

# Retrieval / embedding cache (regenerated at runtime)
data/cache/
# Cost ledger (local per-machine spend tracking)
data/cost_ledger.json
# Per-run outputs (regenerated; don't commit)
data/runs/
# Large benchmark data (downloaded separately)
data/hle/
data/medxpertqa_mm/

# Python
__pycache__/
*.pyc
*.pyo
*.egg-info/
dist/
build/
.eggs/

# Environment
.env
.venv/
env/

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Session logs (may contain sensitive data)
*.jsonl
!data/**/*.jsonl

# Experiment results (generated by benchmark runs; not committed)
results/

# Pytest
.pytest_cache/
.coverage
htmlcov/

# Jupyter
.ipynb_checkpoints/

# Local reference clones
references/
