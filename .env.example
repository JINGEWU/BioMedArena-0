# BioMedArena environment template.
#
# Copy to .env and fill in the keys you plan to use. .env is gitignored.
# Keys whose value is left blank will be treated as "not set" by the CLI.

# ---- LLM providers ----

# Anthropic (Claude Sonnet 4.5, Claude Opus 4.5)
ANTHROPIC_API_KEY=

# OpenAI (GPT-4o, embeddings for tool retrieval)
OPENAI_API_KEY=

# Google Gemini (Gemini 2.5 Flash)
GEMINI_API_KEY=

# xAI / Grok. XAI_MODEL can override the default Grok backbone model.
XAI_API_KEY=
XAI_MODEL=

# Hosted OpenAI-compatible inference providers.
# Set *_MODEL to the exact chat model served by the provider.
GROQ_API_KEY=
GROQ_MODEL=
TOGETHER_API_KEY=
TOGETHER_MODEL=
FIREWORKS_API_KEY=
FIREWORKS_MODEL=

# HuggingFace Inference Providers / router, using OpenAI-compatible chat.
HF_LLM_MODEL=

# Generic OpenAI-compatible endpoint. Useful for custom hosted routers.
OPENAI_COMPATIBLE_API_KEY=
OPENAI_COMPATIBLE_MODEL=
OPENAI_COMPATIBLE_BASE_URL=

# Local OpenAI-compatible servers. These cover vLLM, TGI, SGLang,
# Ollama, LM Studio, llama.cpp, and similar runtimes.
LOCAL_LLM_MODEL=
LOCAL_LLM_API_KEY=
LOCAL_LLM_BASE_URL=
VLLM_BASE_URL=
TGI_BASE_URL=
SGLANG_BASE_URL=
OLLAMA_MODEL=
LMSTUDIO_MODEL=
LLAMACPP_BASE_URL=

# ---- HuggingFace (required for gated benchmarks) ----
#
# Needed for gated benchmark sources such as LAB-Bench 2 and HLE-Gold.
# Get a token at https://huggingface.co/settings/tokens and accept the
# dataset terms at each gated dataset page.
HF_TOKEN=

# ---- Optional: domain-specific API keys ----

# NCBI E-utilities (higher rate limits)
NCBI_API_KEY=

# OMIM REST API
OMIM_API_KEY=

# ---- Optional: Web search tools (Serper + Jina) ----
#
# Required for --web-tools only|combined mode.
# Get a Serper API key at https://serper.dev/
SERPER_API_KEY=

# Optional: Jina Reader API (free tier works without key, but rate-limited)
# Get a key at https://jina.ai/reader/
JINA_API_KEY=
